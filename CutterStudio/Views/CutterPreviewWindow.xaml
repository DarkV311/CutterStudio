<Window x:Class="CutterStudio.Views.CutterPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CutterStudio.Controls"
        Title="Cutter and Vinyl Preview" Width="900" Height="650"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Margin="12" CornerRadius="6" ClipToBounds="True">
            <controls:CutterMachinePreview Document="{Binding PreviewArtwork}"
                                           Metrics="{Binding LayoutMetrics}"
                                           ProfileName="{Binding Settings.CutterProfile}"/>
        </Border>
        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" Padding="14">
            <DockPanel>
                <Button DockPanel.Dock="Right" Width="110" Click="Close_Click">Close</Button>
                <StackPanel>
                    <TextBlock Text="{Binding RequiredVinylText}" FontSize="16"
                               FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="Add the chosen safety margin around the complete cut job."
                               Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
