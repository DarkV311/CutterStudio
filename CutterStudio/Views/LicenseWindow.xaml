<Window x:Class="CutterStudio.Views.LicenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cutter Studio License" Width="520" Height="300"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="License Required" FontSize="24" FontWeight="SemiBold"/>
            <TextBlock Text="Enter your license key to activate Cutter Studio."
                       Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,18"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <TextBlock Text="License Key" Foreground="{StaticResource MutedTextBrush}"/>
            <TextBox x:Name="LicenseKeyBox"/>
            <TextBlock x:Name="StatusText" Text="Not activated"
                       Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap"
                       Margin="0,10,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="ActivateButton" Width="120" Click="ActivateButton_Click">Activate</Button>
            <Button Width="90" Click="ExitButton_Click">Exit</Button>
        </StackPanel>
    </Grid>
</Window>
